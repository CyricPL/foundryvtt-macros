// An Age Passes — Mythic Bastionland macro for Foundry VTT V13
//
// Displays a dialog listing all Knight actors with multi-select checkboxes.
//
// On confirm:
//
// 1. Restore: Set all Virtue values to their max for every selected knight.
//
// 2. Age: Each selected knight ages one step (Young → Mature → Old).
//    Virtue re-rolls (1d12+1d6 per Virtue):
//      Young → Mature: keep the roll if higher than current.
//      Mature → Old:   keep the roll if lower than current.
//      Both value and max are updated together.
//
// 3. Already Old knights (no age change):
//    Lose 1d12 from Vigour (both value and max, clamped to 0).
//    Flagged as diedOfOldAge if Vigour reaches 0.

(async () => {
  // --- Ensure "Deceased" folder exists in the Actor directory ---
  let deceasedFolder = game.folders.find(f => f.type === "Actor" && f.name === "Deceased");
  if (!deceasedFolder) {
    deceasedFolder = await Folder.create({ name: "Deceased", type: "Actor" });
  }

  // Gather all actors of type "knight", excluding those already in the Deceased folder
  const knights = game.actors.filter(a => a.type === "knight" && a.folder?.id !== deceasedFolder.id);

  if (!knights.length) {
    ui.notifications.warn("No Knights found in the world.");
    return;
  }

  // Build the checkbox list HTML
  const checkboxes = knights
    .map(k => {
      const img = k.img || "icons/svg/mystery-man.svg";
      return `
      <label class="age-knight-entry" style="
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 8px;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.15s;
      " onmouseover="this.style.background='rgba(255,255,255,0.05)'"
        onmouseout="this.style.background='transparent'">
        <input type="checkbox" name="knights" value="${k.id}"
          style="width: 16px; height: 16px; cursor: pointer;" />
        <img src="${img}" alt="${k.name}"
          style="width: 36px; height: 36px; border-radius: 4px; border: 1px solid #555; object-fit: cover;" />
        <span style="font-size: 14px;">${k.name}</span>
      </label>`;
    })
    .join("");

  const content = `
    <style>
      .age-passes-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
        max-height: 400px;
        overflow-y: auto;
        padding: 4px 0;
      }
      .age-select-controls {
        display: flex;
        gap: 8px;
        margin-bottom: 6px;
        font-size: 12px;
      }
      .age-select-controls a {
        cursor: pointer;
        text-decoration: underline;
      }
    </style>
    <div class="age-select-controls">
      <a id="age-select-all">Select All</a>
      <a id="age-select-none">Select None</a>
    </div>
    <div class="age-passes-list">
      ${checkboxes}
    </div>
  `;

  const result = await foundry.applications.api.DialogV2.wait({
    window: { title: "An Age Passes" },
    content,
    buttons: [
      {
        action: "confirm",
        label: "Confirm",
        icon: "fa-solid fa-check",
        default: true,
        callback: (event, button, dialog) => {
          const checked = button.form.querySelectorAll('input[name="knights"]:checked');
          return Array.from(checked).map(cb => cb.value);
        }
      },
      {
        action: "cancel",
        label: "Cancel",
        icon: "fa-solid fa-xmark"
      }
    ],
    render: (event, dialog) => {
      const html = dialog.element;
      html.querySelector("#age-select-all")?.addEventListener("click", () => {
        html.querySelectorAll('input[name="knights"]').forEach(cb => cb.checked = true);
      });
      html.querySelector("#age-select-none")?.addEventListener("click", () => {
        html.querySelectorAll('input[name="knights"]').forEach(cb => cb.checked = false);
      });
    },
    rejectClose: false
  });

  // Cancel or closed
  if (!result || result === "cancel") return;

  // result is the array of selected actor IDs
  const selectedKnights = result.map(id => game.actors.get(id)).filter(Boolean);

  if (!selectedKnights.length) {
    ui.notifications.info("No Knights were selected.");
    return;
  }

  const AGE_ORDER = ["young", "mature", "old"];
  const VIRTUES = ["vigour", "clarity", "spirit"];

  // --- Pre-step: Restore all Virtues to max ---
  // Before any aging occurs, set each selected knight's Virtue values equal to their max.
  for (const knight of selectedKnights) {
    const v = knight.system.virtues;
    const restoreData = {};
    for (const virtue of VIRTUES) {
      if (v[virtue].value !== v[virtue].max) {
        restoreData[`system.virtues.${virtue}.value`] = v[virtue].max;
      }
    }
    if (Object.keys(restoreData).length) {
      await knight.update(restoreData);
    }
  }

  // --- Glory: Increase by 1 for all selected knights ---
  for (const knight of selectedKnights) {
    const currentGlory = knight.system.glory?.value ?? 0;
    await knight.update({ "system.glory.value": currentGlory + 1 });
  }

  // --- Age Progression ---
  // Age advances one step: young → mature → old. Old does not change.

  // Build an array of result objects tracking each knight's transition.
  // Shape: {
  //   actor, previousAge, newAge, aged,
  //   virtueChanges: { vigour: {old, rolled, new}, clarity: {...}, spirit: {...} },
  //   vigourLoss: { old, rolled, new } | null,   // only for already-old knights
  //   diedOfOldAge: boolean
  // }
  const ageResults = [];

  for (const knight of selectedKnights) {
    const previousAge = knight.system.age ?? "young";
    const currentIndex = AGE_ORDER.indexOf(previousAge);

    const isAlreadyOld = currentIndex >= AGE_ORDER.length - 1;
    const newAge = isAlreadyOld ? previousAge : AGE_ORDER[currentIndex + 1];

    const entry = {
      actor: knight,
      previousAge,
      newAge,
      aged: !isAlreadyOld,
      virtueChanges: {},
      vigourLoss: null,
      diedOfOldAge: false
    };

    const updateData = {};

    if (!isAlreadyOld) {
      // --- Young → Mature or Mature → Old: Virtue re-rolls ---
      // Roll 1d12+1d6 for each Virtue.
      //   Young → Mature: keep the roll if HIGHER than current.
      //   Mature → Old:   keep the roll if LOWER than current.
      const keepHigher = (previousAge === "young");

      for (const virtue of VIRTUES) {
        const currentVal = knight.system.virtues[virtue].value;
        const roll = await new Roll("1d12 + 1d6").evaluate();
        const rolled = roll.total;

        let newVal;
        if (keepHigher) {
          newVal = rolled > currentVal ? rolled : currentVal;
        } else {
          newVal = rolled < currentVal ? rolled : currentVal;
        }

        entry.virtueChanges[virtue] = {
          old: currentVal,
          rolled,
          new: newVal
        };

        if (newVal !== currentVal) {
          updateData[`system.virtues.${virtue}.value`] = newVal;
          updateData[`system.virtues.${virtue}.max`] = newVal;
        }
      }

      // Update the age
      updateData["system.age"] = newAge;

    } else {
      // --- Already Old: Vigour reduction ---
      // Lose 1d12 from both max and current Vigour. Clamp to 0.
      const currentVal = knight.system.virtues.vigour.value;
      const currentMax = knight.system.virtues.vigour.max;
      const roll = await new Roll("1d12").evaluate();
      const rolled = roll.total;

      const newVal = Math.max(0, currentVal - rolled);
      const newMax = Math.max(0, currentMax - rolled);

      entry.vigourLoss = {
        old: currentVal,
        rolled,
        new: newVal
      };

      if (newVal <= 0) {
        entry.diedOfOldAge = true;
      }

      updateData["system.virtues.vigour.value"] = newVal;
      updateData["system.virtues.vigour.max"] = newMax;
    }

    // Apply all updates in a single call
    if (Object.keys(updateData).length) {
      await knight.update(updateData);
    }

    ageResults.push(entry);
  }

  // --- Build Chat Card ---
  // Matches the Mythic Bastionland system's chat card styling:
  // bordered card, dark header bar, light content area.

  // Helper: capitalize first letter
  const cap = s => s.charAt(0).toUpperCase() + s.slice(1);

  // Helper: format knight name with title
  // system.knight holds the knight's title, e.g. "the Riddle Knight"
  const knightLabel = (actor) => {
    const title = actor.system.knight?.trim();
    return title ? `${actor.name}, ${title},` : `${actor.name}`;
  };

  let cardEntries = "";

  for (const r of ageResults) {
    if (r.aged) {
      // Knight who aged: "{Name}, {Known as the}, grew {newAge}."
      let entry = `<p><strong>${knightLabel(r.actor)}</strong> grew ${r.newAge}.</p>`;

      // Bullet list of Virtues that changed
      const changedVirtues = VIRTUES.filter(v => r.virtueChanges[v]?.new !== r.virtueChanges[v]?.old);
      if (changedVirtues.length) {
        entry += `<ul style="list-style: disc; padding-left: 1.5em; margin: 0.25em 0 0.75em;">`;
        for (const v of changedVirtues) {
          entry += `<li>${cap(v)} is now ${r.virtueChanges[v].new}.</li>`;
        }
        entry += `</ul>`;
      }

      cardEntries += entry;

    } else if (r.diedOfOldAge) {
      // Knight who died of old age
      cardEntries += `<p><strong>${knightLabel(r.actor)}</strong> died peacefully of old age.</p>`;

    } else {
      // Already old, survived: diminished by age
      const newMax = r.vigourLoss?.new ?? r.actor.system.virtues.vigour.max;
      cardEntries += `<p><strong>${knightLabel(r.actor)}</strong> is diminished by age. Vigour is now ${newMax}.</p>`;
    }
  }

  const chatContent = `
    <div class="mythicbastionland" style="
      border: 2px solid #8a7a6b;
      border-radius: 4px;
      overflow: hidden;
      font-family: inherit;
    ">
      <div style="
        background: linear-gradient(to bottom, #6b5a6b, #5a4a5a);
        color: #fff;
        text-align: center;
        padding: 6px 10px;
        font-size: 1.1em;
        font-weight: bold;
        letter-spacing: 0.5px;
      ">An Age Passes</div>
      <div style="
        background: #f5f0eb;
        color: #1a1a1a;
        padding: 10px 12px;
        font-size: 0.95em;
        line-height: 1.5;
      ">
        ${cardEntries}
        <hr style="border: none; border-top: 1px solid #c0b8a8; margin: 0.75em 0;">
        <p><strong>All knights choose one:</strong></p>
        <ul style="list-style: disc; padding-left: 1.5em; margin: 0.25em 0 0;">
          <li><strong>Duty:</strong> Make a significant improvement to the Realm.</li>
          <li><strong>Succession:</strong> Establish a successor and/or have them Knighted.</li>
          <li><strong>Legacy:</strong> Your successor gains half of your current Glory.</li>
        </ul>
      </div>
    </div>
  `;

  await ChatMessage.create({ content: chatContent });

  // --- Move deceased knights to the Deceased folder ---
  const deceased = ageResults.filter(r => r.diedOfOldAge);
  for (const r of deceased) {
    await r.actor.update({ folder: deceasedFolder.id });
  }

  // Log the full results for downstream logic
  console.log("An Age Passes — Results:", ageResults);
})();
